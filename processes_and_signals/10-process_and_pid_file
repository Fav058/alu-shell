#!/usr/bin/env bash
PID_FILE="/var/run/myscript.pid"

cleanup() {
  rm -f "$PID_FILE"
  exit 0
}

on_sigterm() {
  echo "I hate the kill command"
  cleanup
}

on_sigint() {
  echo "Y U no love me?!"
}

trap on_sigterm TERM
trap on_sigint INT
trap cleanup QUIT

echo $$ > "$PID_FILE"

while true; do
  echo "To infinity and beyond"
  sleep 2
done

